<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <config>
    <!-- Avoid NU1301 when repository signature endpoint is unreachable (e.g. restricted network). -->
    <add key="signatureValidationMode" value="accept" />
  </config>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
