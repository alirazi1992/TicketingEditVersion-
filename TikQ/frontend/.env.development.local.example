# Copy to .env.development.local for local dev (gitignored).
# Used only when running: next dev
# Production uses .env.production and must NOT use this file.
# Default (no env) is http://localhost:5000 to match tools/run-backend.ps1.
# For IIS on 8080 use: NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
