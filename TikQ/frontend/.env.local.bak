# TikQ Frontend Environment Configuration
# This file sets the explicit backend API URL to avoid auto-detection issues

# Backend API URL - MUST match the URL where backend is running
# Default: http://localhost:5000 (same as backend's UseUrls in Program.cs)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# NOTE: If you change the backend port in Program.cs or via ASPNETCORE_URLS,
# update this URL to match.
# 
# TROUBLESHOOTING:
# 1. If frontend shows empty data, first check /api/health endpoint
# 2. Open browser devtools Network tab to verify API calls are reaching backend
# 3. Use /api/debug/data-status to verify database has data
